# OpenAI (Realtime tutor)
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-mini

# Neon Postgres (waitlist, tutor usage, feedback, …)
NEON_DATABASE_URL=

# Neon Auth — create in Neon Console; cookie secret: random string, 32+ characters
# Client sign-up validation uses lib/auth/password-policy.ts (AUTH_PASSWORD_MIN_LENGTH); keep it in sync with Neon Auth password rules in the console.
NEON_AUTH_BASE_URL=
NEXT_PUBLIC_NEON_AUTH_URL=
NEON_AUTH_COOKIE_SECRET=

# tldraw
NEXT_PUBLIC_TLDRAW_LICENSE_KEY=
